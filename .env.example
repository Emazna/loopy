# Codexが作業するフォルダ（未設定ならLoopyを起動したフォルダを使う）
# LOOP_CANVAS_WORKDIR=C:\path\to\your\workspace
LOOP_CANVAS_MODEL=gpt-5.4
# Defaults to %LOCALAPPDATA%\Emazna\LoopCanvas\loop-canvas.sqlite3
# LOOP_CANVAS_DB_PATH=C:\path\to\loop-canvas.sqlite3
# Leave unset to use the currently logged-in Codex home.
# LOOP_CANVAS_CODEX_HOME=C:\Users\you\.codex
LOOP_CANVAS_CODEX_BIN=codex
LOOP_CANVAS_REASONING_EFFORT=high
